<mujocoinclude>

	<!-- Освещение -->
	<light cutoff="4.0" diffuse="1 1 1" dir="-0.9 -0.9 -2.5" directional="true" exponent="20" pos="0.9 0.9 2.5" specular="0 0 0" />
	<light cutoff="4.0" diffuse="0.6 0.6 0.7" dir="1 -1 -1.5" directional="true" exponent="20" pos="-1.5 1.5 3.0" specular="0 0 0" />

	<!-- Пол (10x10м) -->
	<geom name="ground" pos="0 0 -0.01" rgba="0.25 0.26 0.25 1" size="5 5 2" type="plane" contype="1" conaffinity="1" />

	<!-- ══════════════════════════════════════════════════
	     МАРШРУТ: старт (-3.5, -4.0) → цель (3.5, -4.0)
	     Прямой путь по Y=-4 намеренно свободен на первых 3м,
	     чтобы агент успел научиться двигаться до первого препятствия.
	     ══════════════════════════════════════════════════ -->

	<!-- Препятствие 1: блок посередине арены, вынуждает объехать -->
	<geom name="block_center" type="box" size="0.6 0.6 0.4" pos="0.0 -2.5 0.4"
	      rgba="0.9 0.2 0.2 1" mass="10" contype="1" conaffinity="1" />

	<!-- Препятствие 2 и 3: сужают проход, но оставляют место для объезда -->
	<geom name="block_left"  type="box" size="0.5 0.5 0.4" pos="-0.5 -1.0 0.4"
	      rgba="0.9 0.2 0.2 1" mass="10" contype="1" conaffinity="1" />
	<geom name="block_right" type="box" size="0.5 0.5 0.4" pos="1.5  -2.5 0.4"
	      rgba="0.9 0.2 0.2 1" mass="10" contype="1" conaffinity="1" />

	<!-- Препятствие 4: сфера на финишной прямой -->
	<geom name="sphere_obs" type="sphere" size="0.5" pos="2.0 -3.0 0.5"
	      rgba="0.2 0.7 0.3 1" mass="5" contype="1" conaffinity="1" />

	<!-- Стены арены -->
	<geom name="wall1" type="box" size="5 0.1 0.6" pos="0 -4.9 0.6" rgba="0.5 0.35 0.2 1" mass="15" contype="1" conaffinity="1" />
	<geom name="wall2" type="box" size="5 0.1 0.6" pos="0  4.9 0.6" rgba="0.5 0.35 0.2 1" mass="15" contype="1" conaffinity="1" />
	<geom name="wall3" type="box" size="0.1 5 0.6" pos=" 4.9 0 0.6" rgba="0.5 0.35 0.2 1" mass="15" contype="1" conaffinity="1" />
	<geom name="wall4" type="box" size="0.1 5 0.6" pos="-4.9 0 0.6" rgba="0.5 0.35 0.2 1" mass="15" contype="1" conaffinity="1" />

	<!-- Цель — оформлена как body чтобы читать xpos из Python -->
	<body name="goal_marker" pos="3.5 -4.0 0.15">
		<geom name="goal" type="sphere" size="0.3" rgba="0 1 0 0.8" contype="0" conaffinity="0"/>
	</body>

	<!-- Визуальный маркер старта -->
	<geom name="start_marker" type="sphere" size="0.15" pos="-3.5 -4.0 0.15"
	      rgba="0.9 0.2 0.2 1" contype="0" conaffinity="0"/>

</mujocoinclude>
